# =============================================
# FunnelBook AI — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env com valores reais
# =============================================

# ----- Supabase (Frontend / público) -----
SUPABASE_PROJECT_ID="seu-project-ref-aqui"
SUPABASE_URL="https://seu-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="eyJ..."   # anon key — público, seguro expor

# Duplicatas para o Vite (necessário para SSR com TanStack Start)
VITE_SUPABASE_PROJECT_ID="seu-project-ref-aqui"
VITE_SUPABASE_URL="https://seu-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJ..."

# ----- Supabase Edge Functions (secrets — nunca exponha) -----
# Configure via: npx supabase secrets set NOME=valor --project-ref SEU_PROJECT_REF
# Ou no Dashboard: Edge Functions → Secrets

# LOVABLE_API_KEY=    ← chave do Lovable AI Gateway (Gemini 2.5 Flash)
# OPENAI_API_KEY=     ← fallback se LOVABLE_API_KEY falhar (GPT-4o-mini)
# SUPABASE_SERVICE_ROLE_KEY=  ← service role key (admin) para as Edge Functions
